# ─────────────────────────────────────────────────────────────────
# Dirty Website — Environment Variables Template
# Copy this file to .env.local and fill in your real values.
# .env.local is NEVER committed to GitHub.
# ─────────────────────────────────────────────────────────────────

# Site URL (update for each environment)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Email Delivery (Resend) ───────────────────────────────────────
# Sign up at resend.com, verify your domain, get your API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The "from" address for outgoing emails — must be on your verified domain
FROM_EMAIL=noreply@dirty.com

# Where booking + contact form submissions get delivered
OWNER_EMAIL=hello@dirty.com

# ── Events CMS (only if using Airtable Option B) ──────────────────
# Leave blank if using the local events.ts file (Option A)
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
